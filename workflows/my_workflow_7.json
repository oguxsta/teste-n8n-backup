      "webhookId": "45626e48-ac6e-4650-8772-acf21d59ed8e"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst raw = (body.contact_phone || '').replace(/\\D/g, '');\n\n// Variante sem o 9 extra: 13 dígitos e 5º dígito = '9'\nlet phone_sem9 = null;\nif (raw.length === 13 && raw[4] === '9') {\n  phone_sem9 = raw.slice(0, 4) + raw.slice(5);\n}\n\n// Variante com 9 adicionado: 12 dígitos e DDD >= 28\nconst ddd = raw.length === 12 ? parseInt(raw.slice(2, 4), 10) : null;\nlet phone_com9 = null;\nif (raw.length === 12 && ddd >= 28) {\n  phone_com9 = raw.slice(0, 4) + '9' + raw.slice(4);\n}\n\nreturn [{\n  json: {\n    contact_name:   body.contact_name  || null,\n    contact_email:  body.contact_email || null,\n    contact_phone:  body.contact_phone || null,\n    phone_clean:    raw,\n    phone_sem9,\n    phone_com9,\n    deal_stage:     body.deal_stage    || null,\n    deal_status:    body.deal_status   || null,\n    deal_user:      body.deal_user     || null,\n    raw_payload:    body\n  }\n}];"
      },
      "id": "fd4b0e83-8005-462a-90a8-4a239c83f74f",
