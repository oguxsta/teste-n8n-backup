    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id FROM leads\nWHERE\n  regexp_replace(phone_number, '[^0-9]', '', 'g') = $1\n  OR ($2 IS NOT NULL AND regexp_replace(phone_number, '[^0-9]', '', 'g') = $2)\n  OR ($3 IS NOT NULL AND regexp_replace(phone_number, '[^0-9]', '', 'g') = $3)\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{ $json.phone_clean }},{{ $json.phone_sem9 }},{{ $json.phone_com9 }}"
        }
